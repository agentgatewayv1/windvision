# roofsat-web backend configuration. Copy to ".env" and fill in.
# The Node server loads this at startup (dotenv). Never commit real values.

# --- Python measurement API (required for live measuring) ---
ROOFSAT_API_URL=https://your-tunnel.trycloudflare.com
ROOFSAT_API_TOKEN=

# --- Supabase (optional: server-side measurement history, syncs across devices) ---
# Project Settings -> Data API / API Keys in your Supabase dashboard.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
